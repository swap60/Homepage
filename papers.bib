
@article{pandey2022high,
  title={High-resolution WENO schemes using local variation-based smoothness indicator},
  author={Pandey, Prashant Kumar and Ismail, Farzad and Dubey, Ritesh Kumar},
  journal={Computational and Applied Mathematics},
  volume={41},
  number={5},
  pages={208},
  year={2022},
  publisher={Springer},
  doi={10.1007/s40314-022-01916-0},
  citations={3},
  abstract={A novel smoothness indicator is proposed herein for WENO schemes based on the point-wise local variation in the candidate stencils. The proposed indicator is further used to define non-linear weights for a WENO scheme.}
}

@article{pandey2023sign,
  title={Sign stable arbitrary high order reconstructions for constructing non-oscillatory entropy stable schemes},
  author={Pandey, Prashant Kumar and Dubey, Ritesh Kumar},
  journal={Applied Mathematics and Computation},
  volume={454},
  pages={128099},
  year={2023},
  publisher={Elsevier},
  doi={https://doi.org/10.1016/j.amc.2023.128099},
  citations={4},
  abstract={High order sign stable reconstructions are much sought after to develop high order non-oscillatory entropy stable schemes. This work presents a very simple but generic approach to construct arbitrary high order sign stable reconstructions. Further, by utilizing such obtained sign stable reconstructions entropy stable schemes are constructed using well known arbitrary high-order entropy conservative fluxes. Several numerical results for 1D and 2D benchmark test problems are given to demonstrate the accuracy and non-oscillatory property of representative entropy stable schemes which are designed using of proposed approach.}
}

@article{kumar2023efficient,
  title={An efficient scaling of WENO-JS weights for accuracy preserving and higher resolution schemes},
  author={Kumar Pandey, Prashant and Kumar Dubey, Ritesh},
  journal={Physica Scripta},
  volume={98},
  number={8},
  pages={085247},
  year={2023},
  publisher={IOP Publishing},
  doi={10.1088/1402-4896/ace85f},
  citations={0},
  abstract={In this short paper, we present efficient scaling of WENO-JS weights which results in robust and formal accuracy-preserving high-resolution WENO-JS schemes. The proposed scaling makes the WENO-JS schemes robust in the sense that schemes works well irrespective of the choice for the parameter epsilon used in classical WENO-JS weights to prevent division by zero. In smooth solution region the proposed scaling keeps the scaled WENO weights in the vicinity of critical weights thus resulting scheme retains formal accuracy. Numerical experiments show that the WENO schemes with scaled weights provide higher resolution for discontinuities as well for smooth solution with high gradients.}
}

@article{jayswal2024eno,
  title={Eno classification and regression neural networks for numerical approximation of discontinuous flow problems},
  author={Jayswal, Vikas Kumar and Pandey, Prashant Kumar and Dubey, Ritesh Kumar},
  journal={Soft Computing},
  volume={28},
  number={20},
  pages={11787--11798},
  year={2024},
  publisher={Springer},
  doi={10.1007/s00500-024-09944-0},
  citations={0},
  abstract={Learning high order non-oscillatory polynomial approximation procedures which form the backbone of high order numerical solution of partial differential equations is challenging. The major issue is to pose these procedures as a learning problem and generate suitable synthetic data set which suffice learning it with small neural networks. In this work, we pose an arc-length based essentially non-oscillatory (ENOL) reconstruction algorithm as machine learning problem. A novel way to construct the synthetic data using ENOL algorithm along with basic smooth and piece-wise continuous functions is given. Small vanilla regression and classification neural networks are trained to learn third order (ENOL) polynomial approximation procedure.}
}

@inproceedings{dubey2020learning,
  title={Learning numerical viscosity using artificial neural regression network},
  author={Dubey, Ritesh Kumar and Gupta, Anupam and Jayswal, Vikas Kumar and Pandey, Prashant Kumar},
  booktitle={International Conference on Computational Sciences-Modelling, Computing and Soft Computing},
  pages={42--55},
  year={2020},
  publisher={Springer},
  doi={10.1007/978-981-16-4772-7_3},
  citations={3},
  abstract={This chapter explores the use of artificial neural regression networks to learn numerical viscosity parameters, bridging classical numerical analysis with modern machine learning techniques for improved computational fluid dynamics simulations.}
}
@article{sahu2026efficient,
  title={Efficient diffusion for high order non-oscillatory entropy stable schemes},
  author={Sahu, Anuradha and Pandey, Prashant Kumar and Dubey, Ritesh Kumar},
  journal={Applied Mathematics and Computation},
  volume={518},
  pages={129901},
  year={2026},
  publisher={Elsevier}
  doi={10.1016/j.amc.2023.128099},
  citations={0},
  abstract={This paper proposes an efficient approach to construct non-oscillatory entropy stable fluxes (F^) by adding an efficient diffusion term to the entropy conservative fluxes.
Computation of proposed diffusion term does not require restrictive and logically expensive sign stability condition on high order reconstruction process or flux sign stability on high order fluxes. The diffusion term is defined as the absolute difference of non-oscillatory (F˘) and entropy conservative fluxes (F˜) multiplied with sign of jump in entropy variable. The amount of diffusion is adjusted using a limiter function without compromising the entropy stability of the resulting scheme which exhibits both high resolution and the non-oscillatory property. The proposed approach is tested on various standard benchmark test problems. Numerical results demonstrate the effectiveness of the method in achieving high resolution entropy stable schemes, 
Moreover the scheme maintains formal order of accuracy of the lower order flux used in defining the diffusion term.
}
